{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "faculty"] },
        "sections": { "type": "array", "items": { "type": "string" } },
        "onboarded": { "type": "boolean" },
        "fcmTokens": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["email", "role", "onboarded"]
    },
    "Task": {
      "title": "Task",
      "description": "A task or assignment",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "completed": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdBy": { "type": "string" },
        "targetSections": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "remindersSent": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "deadline", "userId", "completed", "createdAt"]
    },
    "SubTask": {
      "title": "SubTask",
      "description": "A subtask within a task",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "completed": { "type": "boolean" }
      },
      "required": ["text", "completed"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Task documents"
    },
    "/tasks/{taskId}/subtasks/{subtaskId}": {
      "schema": "SubTask",
      "description": "Subtask documents"
    }
  }
}
